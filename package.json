{
  "name": "llm-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./src/app/*",
    "#audio/*": "./src/audio/*",
    "#config/*": "./src/config/*",
    "#contentSafety/*": "./src/contentSafety/*",
    "#comfy/*": "./src/comfy/*",
    "#conversation/*": "./src/conversation/*",
    "#data/*": "./src/data/*",
    "#forwards/*": "./src/forwards/*",
    "#identity/*": "./src/identity/*",
    "#images/*": "./src/images/*",
    "#internalApi/*": "./src/internalApi/*",
    "#llm/*": "./src/llm/*",
    "#memory/*": "./src/memory/*",
    "#messages/*": "./src/messages/*",
    "#modes/*": "./src/modes/*",
    "#persona/*": "./src/persona/*",
    "#requests/*": "./src/requests/*",
    "#runtime/*": "./src/runtime/*",
    "#services/*": "./src/services/*",
    "#types/*": "./src/types/*",
    "#utils/*": "./src/utils/*"
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "npm run build:bot && npm run build:webui",
    "build:bot": "tsdown",
    "build:webui": "npm --prefix webui run build",
    "dev": "NODE_ENV=development node scripts/dev.mjs",
    "dev:bot": "NODE_ENV=development LLM_BOT_WEBUI_MODE=external tsx watch src/index.ts",
    "dev:webui": "NODE_ENV=development npm --prefix webui run dev",
    "install:browsers": "playwright install chromium",
    "cleanup:invalid-chat-media": "npx tsx scripts/cleanup-invalid-chat-media.ts",
    "migrate:memory": "npx tsx scripts/migrate-memory-refactor.ts",
    "start:bot": "NODE_ENV=production node dist/index.mjs",
    "start:webui": "NODE_ENV=production npm --prefix webui run preview",
    "test": "npm run test:bot && npm run test:webui",
    "test:bot": "node test/run-node-tests.mjs",
    "test:bot:serial": "node test/run-node-tests.mjs --serial",
    "test:webui": "npm run build:webui",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:test"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.1",
    "@simplewebauthn/server": "^13.3.0",
    "croner": "^10.0.1",
    "fastify": "^5.8.5",
    "jsonrepair": "^3.14.0",
    "node-pty": "^1.1.0",
    "p-queue": "^9.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "undici": "^8.1.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
